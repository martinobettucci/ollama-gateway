# PROD (hôte self-hosted) — termine le TLS de llm.example.com et route vers le proxy local.
# Écoute sur 11435 (cible du forward box 21434 → 11435). Certificat Let's Encrypt obtenu
# par challenge DNS-01 Scaleway (100 % sortant : ni 80 ni 443 requis en entrée).
#
# Secrets : SCW_SECRET_KEY + SCW_DEFAULT_ORGANIZATION_ID (token API Scaleway, perms Domains/DNS)
# fournis via .env.prod — jamais committé. Aucune valeur secrète ni topologie réelle ici.

{
	# En DNS-01 sur port non-standard : pas de redirection HTTP → n'ouvre pas :80 (souvent occupé).
	auto_https disable_redirects
	# email {env.ACME_EMAIL}
}

llm.example.com:11435 {
	tls {
		dns scaleway {
			secret_key {env.SCW_SECRET_KEY}
			organization_id {env.SCW_DEFAULT_ORGANIZATION_ID}
		}
		# L'API DNS Scaleway EXIGE un TTL sur l'enregistrement TXT du challenge.
		dns_ttl 3600s
		propagation_timeout 300s
	}

	# Seuls les chemins d'inférence sont proxifiés ; tout le reste (dont /admin) → 404.
	@infer path /api/* /v1/* /_proxy_health
	handle @infer {
		reverse_proxy 127.0.0.1:8787 {
			flush_interval -1        # streaming NDJSON/SSE en temps réel (pas de buffering)
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}
	handle {
		respond 404
	}
}
