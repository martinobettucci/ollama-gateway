# PROD — termine le TLS du domaine public de la passerelle et route vers le proxy local.
# Domaine et port d'écoute paramétrés par environnement (GATEWAY_DOMAIN, GATEWAY_TLS_PORT), pour
# ne coder aucun hôte réel dans le dépôt. Certificat Let's Encrypt obtenu par challenge DNS-01
# Scaleway (100 % sortant : ni 80 ni 443 requis en entrée), adapté à un port non standard derrière
# un forward NAT.
#
# Secrets : SCW_SECRET_KEY + SCW_DEFAULT_ORGANIZATION_ID (token API Scaleway, perms Domains/DNS)
# fournis via .env.prod — jamais committé. Aucune valeur secrète ni topologie réelle ici.

{
	# En DNS-01 sur port non-standard : pas de redirection HTTP → n'ouvre pas :80 (souvent occupé).
	auto_https disable_redirects
	# email {env.ACME_EMAIL}
}

{$GATEWAY_DOMAIN}:{$GATEWAY_TLS_PORT} {
	tls {
		dns scaleway {
			secret_key {env.SCW_SECRET_KEY}
			organization_id {env.SCW_DEFAULT_ORGANIZATION_ID}
		}
		# L'API DNS Scaleway EXIGE un TTL sur l'enregistrement TXT du challenge.
		dns_ttl 3600s
		propagation_timeout 300s
	}

	# En-têtes de sécurité côté public (API JSON). HSTS force le TLS ; nosniff bloque le MIME
	# sniffing ; on retire la bannière `Server`. Pas de CSP ici : la surface publique ne rend pas
	# de HTML navigateur (le panel HTML est LAN-only et hors Caddy).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		-Server
	}

	# Seuls les chemins d'inférence sont proxifiés ; tout le reste (dont /admin) → 404.
	@infer path /api/* /v1/* /_proxy_health
	handle @infer {
		# Borne de taille du corps (défense en profondeur anti-DoS mémoire ; le proxy re-vérifie
		# via MAX_REQUEST_BYTES). Généreux pour l'image-to-image base64.
		request_body {
			max_size 100MB
		}
		reverse_proxy 127.0.0.1:8787 {
			flush_interval -1        # streaming NDJSON/SSE en temps réel (pas de buffering)
			transport http {
				read_timeout 3600s
				write_timeout 3600s
			}
		}
	}
	handle {
		respond 404
	}
}
