#!/usr/bin/env bash
# PROD (hôte self-hosted) : build + up sans purge du volume (données/clés persistantes). Requiert .env.prod.
set -euo pipefail
cd "$(dirname "$0")"
if [ ! -f .env.prod ]; then
  echo "ERREUR : .env.prod manquant. Copier .env.prod.example et le renseigner." >&2
  exit 1
fi

# ── Gate de sécurité pré-déploiement (règle dure, cf. CLAUDE.md) ──────────────────────────────
# Balayage complet (secrets, CVE deps, SAST, tests) ; TOUTE découverte STOPPE le déploiement.
# Contournement explicite et tracé : ALLOW_INSECURE_DEPLOY=1 ./runProd (décision consciente).
if [ "${ALLOW_INSECURE_DEPLOY:-0}" = "1" ]; then
  echo "⚠️  ALLOW_INSECURE_DEPLOY=1 : balayage de sécurité CONTOURNÉ (déploiement forcé)." >&2
else
  if ! ./scripts/security-sweep.sh; then
    echo >&2
    echo "⛔ Déploiement STOPPÉ par le balayage de sécurité (voir le résumé ci-dessus)." >&2
    echo "   Corriger les découvertes, ou forcer : ALLOW_INSECURE_DEPLOY=1 ./runProd" >&2
    exit 2
  fi
fi

# --env-file : compose interpole ${ADMIN_BIND_IP} depuis .env.prod (pas seulement env_file interne).
C="docker compose --env-file .env.prod -f docker-compose.prod.yml"
$C up -d --build
$C ps
echo
echo "  Proxy (loopback)  : http://127.0.0.1:8787/_proxy_health"
echo "  Admin (LAN)       : http://<ADMIN_BIND_IP>:8788/admin"
echo "  Public via Caddy  : https://<GATEWAY_DOMAIN>:<port-public>/_proxy_health (forward NAT → GATEWAY_TLS_PORT)"
