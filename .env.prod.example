# .env.prod — variables de production (hôte self-hosted). Copier en `.env.prod` et renseigner. NE PAS committer.
# Chaque variable est commentée : rôle + valeur attendue.

# IP LAN sur laquelle l'admin écoute (JAMAIS forwardée à l'extérieur). Ex. l'IP LAN de la box.
ADMIN_BIND_IP=192.168.1.10

# Mot de passe admin initial (posé au premier démarrage seulement, si aucun n'existe déjà).
# Après init, se change via… (à défaut, supprimer la ligne admin_auth et redémarrer). Min 8 car.
ADMIN_PASSWORD=change-me-strong

# Secret de signature des cookies de session admin. Chaîne aléatoire longue (ex. `openssl rand -hex 32`).
ADMIN_SESSION_SECRET=change-me-random-hex

# Clé maître de chiffrement au repos des jetons d'auth des serveurs Ollama distants (Fernet).
# Chaîne aléatoire longue (ex. `openssl rand -hex 32`). NE PAS committer, NE PAS changer après coup
# (la changer rend les jetons distants stockés illisibles → il faut les ressaisir dans l'admin).
P2E_MASTER_KEY=change-me-random-hex-2

# URL publique de la passerelle telle que la voient les CLIENTS (le vhost servi par Caddy,
# sans slash final). Sert uniquement à l'admin pour générer les variables d'environnement
# prêtes à copier (modale à la création d'une clé) : OLLAMA_HOST / OPENAI_BASE_URL / etc.
PUBLIC_BASE_URL=https://passerelle.example.com

# Token API Scaleway pour le challenge DNS-01 de Caddy (émission/renouvellement du cert
# llm.example.com). Permissions Domains/DNS. Fourni au conteneur Caddy. NE JAMAIS committer.
# SCW_SECRET_KEY + SCW_DEFAULT_ORGANIZATION_ID sont REQUIS par le module caddy-dns/scaleway.
SCW_SECRET_KEY=scw-secret-key-here
SCW_DEFAULT_ORGANIZATION_ID=scw-organization-id-here
# (Optionnels selon la portée du token — inoffensifs à laisser :)
SCW_ACCESS_KEY=scw-access-key-here
SCW_DEFAULT_PROJECT_ID=scw-project-id-here

# (Optionnel) e-mail ACME Let's Encrypt — décommenter aussi la ligne email du Caddyfile.
# ACME_EMAIL=admin@example.org
